<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  구조 예시 전용 — 실 파일은 Firebase 콘솔에서 받아
  ios/Runner/GoogleService-Info.plist 로 저장(커밋 금지). 절차: docs/FCM_SETUP.md
  실제 파일은 Xcode에서 Runner 타깃에 "Add Files to Runner"로 포함시켜야 번들된다.
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>&lt;IOS_API_KEY&gt;</string>
	<key>GCM_SENDER_ID</key>
	<string>&lt;MESSAGING_SENDER_ID&gt;</string>
	<key>BUNDLE_ID</key>
	<string>ai.devpath.devpath_mobile</string>
	<key>PROJECT_ID</key>
	<string>&lt;FIREBASE_PROJECT_ID&gt;</string>
	<key>STORAGE_BUCKET</key>
	<string>&lt;FIREBASE_PROJECT_ID&gt;.appspot.com</string>
	<key>GOOGLE_APP_ID</key>
	<string>&lt;IOS_APP_ID&gt;</string>
	<key>IS_GCM_ENABLED</key>
	<true/>
</dict>
</plist>
