{
  "_comment": "구조 예시 전용 — 실 파일은 Firebase 콘솔에서 받아 android/app/google-services.json 로 저장(커밋 금지). 절차: docs/FCM_SETUP.md",
  "project_info": {
    "project_number": "<MESSAGING_SENDER_ID>",
    "project_id": "<FIREBASE_PROJECT_ID>",
    "storage_bucket": "<FIREBASE_PROJECT_ID>.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "<ANDROID_APP_ID>",
        "android_client_info": {
          "package_name": "ai.devpath.devpath_mobile"
        }
      },
      "api_key": [
        {
          "current_key": "<ANDROID_API_KEY>"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
